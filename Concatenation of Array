class Solution {
    public int[] getConcatenation(int[] nums) {
        int n=nums.length;
        int c=0;
        int j=0;
        int[] arr=new int[n*2];
        for(int i=0;i<2*n;i++)
        {
            arr[i]=nums[j++];
            c++;
            if(c==n)
            {
                j=0;
            }
        }
        return arr;
    }
}
