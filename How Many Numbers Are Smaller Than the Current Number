class Solution {
    public int[] smallerNumbersThanCurrent(int[] nums) {
        int n=nums.length;  
        int k=0;
        int[] arr=new int[n];
        for(int i=0;i<n;i++)
        {
            int c=0;
            int j=0;
            while(j<n)
            {
              if(nums[i]>nums[j])
              {
                c++;
              }
              j++;
            }
            arr[k++]=c;
        }
        return arr;
    }
}
