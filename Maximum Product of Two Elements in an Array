class Solution {
    public int maxProduct(int[] nums) {
        int n=nums.length;
        int m=1;
        int maxi=0;
        for(int i=0;i<n-1;i++)
        {
            for(int j=i+1;j<n;j++)
            {
                m=(nums[j]-1)*(nums[i]-1);
                if(m>maxi)
                {
                    maxi=m;
                }
            }
        }
        return maxi;
    }
}
