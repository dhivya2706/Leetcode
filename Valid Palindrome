class Solution {
    public boolean isPalindrome(String s) {
        int n = s.length();
        String str = "";
        
        for (int i = 0; i < n; i++) {
            char ch = Character.toLowerCase(s.charAt(i));
            
            if (Character.isLetterOrDigit(ch)) {
                str = str + ch;
            }
        }

        int n1 = str.length();
        for (int i = 0; i < n1 / 2; i++) {
            if (str.charAt(i) != str.charAt(n1 - 1 - i)) {
                return false;
            }
        }
        
        return true;
    }
}
