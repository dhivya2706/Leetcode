import java.util.Arrays;

public class RemoveDuplicatesInPlace {
    public static void main(String[] args) {
        int[] arr = {4, 2, 2, 3, 1, 4, 3};

        Arrays.sort(arr);

        int j = 0;

        for (int i = 1; i < arr.length; i++) {
            if (arr[i] != arr[j]) {
                arr[++j] = arr[i];
            }
        }
        for (int i = 0; i <= j; i++) {
            System.out.print(arr[i] + " ");
        }
    }
}
