class Solution {
    public boolean isAnagram(String s, String t) {
        char[] arr1=s.toCharArray();
        Arrays.sort(arr1);
        char[] arr2=t.toCharArray();
        Arrays.sort(arr2);
        int n1=s.length();
        int n2=t.length();
        if(n1!=n2)
        {
            return false;
        }
        else
        {
            for(int i=0;i<n1;i++)
            {
                char a=arr1[i];
                char b=arr2[i];
                if(a!=b)
                {
                    return false;
                }
            }
            return true;
        }
    }
}
